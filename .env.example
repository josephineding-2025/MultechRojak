# Copy this file to .env and fill in your keys before running the backend
# Never commit .env to git

# OpenRouter — unified LLM gateway (replaces direct OpenAI + Gemini keys)
# Get key at: https://openrouter.ai/keys
# Uses the OpenAI-compatible API; no extra package needed.
OPENROUTER_API_KEY=sk-or-...

# Model to use for chat/video analysis (vision-capable required)
# Good options for real-time use (low latency):
#   openai/gpt-4o-mini           — fast, cheap, vision-capable
#   openai/gpt-4o                — best quality, higher cost
#   google/gemini-flash-1.5      — very fast, strong multilingual
#   anthropic/claude-3-5-haiku   — fast, strong reasoning
# See full model list: https://openrouter.ai/models
OPENROUTER_CHAT_MODEL=google/gemini-flash-1.5

# Model for audio transcription (Whisper remains direct OpenAI — no OpenRouter equivalent)
# Leave blank to skip audio monitoring
OPENAI_API_KEY=sk-...

# SerpAPI — reverse image search for background checks
SERPAPI_KEY=...

# NumVerify — phone number validation
NUMVERIFY_API_KEY=...

# Supabase — community flagging database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
