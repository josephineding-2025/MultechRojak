# Copy this file to .env and fill in your keys before running the backend
# Never commit .env to git

# OpenAI — used for GPT-4o chat/video analysis and Whisper transcription
OPENAI_API_KEY=sk-...

# Google Gemini — alternative vision LLM
GEMINI_API_KEY=...

# SerpAPI — reverse image search for background checks
SERPAPI_KEY=...

# NumVerify — phone number validation
NUMVERIFY_API_KEY=...

# Supabase — community flagging database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
